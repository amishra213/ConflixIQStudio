imary-foreground'\n                                  : 'bg-muted text-muted-foreground'\n                              }\n                            >\n                              {task.status}\n                            </Badge>\n                            <span className=\"text-xs text-muted-foreground\">Task #{index + 1}</span>\n                          </div>\n                          <Button\n                            variant=\"ghost\"\n                            size=\"sm\"\n                            className=\"text-muted-foreground hover:text-foreground\"\n                            onClick={(e) => {\n                              e.stopPropagation();\n                              toggleTaskExpansion(index);\n                            }}\n                          >\n                            {isExpanded ? (\n                              <ChevronDownIcon className=\"w-4 h-4\" />\n                            ) : (\n                              <ChevronRightIcon className=\"w-4 h-4\" />\n                            )}\n                          </Button>\n                        </div>\n                        \n                        <div className=\"flex items-center gap-4 text-xs text-muted-foreground\">\n                          {task.startTime && (\n                            <span>Started: {new Date(task.startTime).toLocaleTimeString()}</span>\n                          )}\n                          {task.endTime && (\n                            <span>Ended: {new Date(task.endTime).toLocaleTimeString()}</span>\n                          )}\n                          {task.startTime && task.endTime && (\n                            <span className=\"text-primary font-medium\">\n                              Duration: {((new Date(task.endTime).getTime() - new Date(task.startTime).getTime()) / 1000).toFixed(2)}s\n                            </span>\n                          )}\n                        </div>\n                      