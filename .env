# Netflix Conductor Configuration
# These variables are used as fallbacks when not specified in the UI

# Conductor Server URL (without /graphql suffix)
VITE_CONDUCTOR_SERVER_URL=http://localhost:8080

# Conductor GraphQL Endpoint (full URL including /graphql)
# Note: Your GraphQL endpoint is on port 4000, while Conductor server is on 8080
VITE_CONDUCTOR_GRAPHQL_URL=http://localhost:4000/graphql

# Conductor API Key (optional - leave empty if not using authentication)
VITE_CONDUCTOR_API_KEY=

# Application Configuration
VITE_APP_NAME=BYConductorStudio
VITE_APP_VERSION=1.0.0

# Development Settings
VITE_DEV_PORT=5173
VITE_API_TIMEOUT=30000
VITE_RETRY_ATTEMPTS=3

# Logging Configuration
VITE_ENABLE_LOGGING=true
VITE_LOG_LEVEL=info

# Example for custom Conductor setup:
# VITE_CONDUCTOR_SERVER_URL=http://your-conductor-server:8080
# VITE_CONDUCTOR_GRAPHQL_URL=http://your-conductor-server:8080/graphql
# VITE_CONDUCTOR_API_KEY=your-api-key-here
