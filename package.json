{
  "version": "1.0.0",
  "source": "./index.html",
  "type": "module",
  "name": "netflix-conductor-hub",
  "description": "Netflix Conductor Hub - A comprehensive visual workflow designer for Netflix Conductor",
  "author": "Conductor Hub Team",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node index.js",
    "server:dev": "node --watch index.js",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npm run build && electron-builder --win",
    "electron-build:publish": "npm run build && electron-builder --win --publish always",
    "docker-build": "docker build -t conductor-designer:latest .",
    "docker-export": "docker save -o conductor-designer.tar conductor-designer:latest",
    "docker-export:gz": "docker save conductor-designer:latest | gzip > conductor-designer.tar.gz",
    "docker-compose": "docker-compose up -d",
    "docker-compose:down": "docker-compose down",
    "docker-compose:logs": "docker-compose logs -f",
    "dist:build-all": "tsx scripts/build-all-distributions.ts",
    "dist:build-id": "tsx scripts/build-id-manager.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.0.9",
    "@apollo/server": "^4.10.1",
    "@radix-ui/react-accordion": "1.2.1",
    "@radix-ui/react-alert-dialog": "1.1.2",
    "@radix-ui/react-aspect-ratio": "1.1.0",
    "@radix-ui/react-avatar": "1.1.1",
    "@radix-ui/react-checkbox": "1.1.2",
    "@radix-ui/react-collapsible": "1.1.1",
    "@radix-ui/react-context-menu": "2.2.2",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-hover-card": "1.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-menubar": "1.1.2",
    "@radix-ui/react-navigation-menu": "1.2.1",
    "@radix-ui/react-popover": "1.1.2",
    "@radix-ui/react-progress": "1.1.0",
    "@radix-ui/react-radio-group": "1.2.1",
    "@radix-ui/react-scroll-area": "1.2.0",
    "@radix-ui/react-select": "2.1.2",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slider": "1.2.1",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-switch": "1.1.1",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-toast": "1.2.1",
    "@radix-ui/react-toggle": "1.1.0",
    "@radix-ui/react-toggle-group": "1.1.0",
    "@radix-ui/react-tooltip": "1.1.3",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.6.0",
    "class-variance-authority": "0.7.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "graphql-type-json": "^0.3.2",
    "gsap": "^3.13.0",
    "lucide-react": "^0.544.0",
    "mermaid": "^10.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.10.0",
    "tailwind-merge": "^1.14.0",
    "uuid": "^10.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/gsap": "^1.20.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "esbuild": "0.25.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "15.12.0",
    "prettier": "^3.2.5",
    "tailwindcss": "3.4.16",
    "tailwindcss-animate": "1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "glob": "12.0.0"
  },
  "alias": {
    "@/*": "./src/components/ui/$1"
  },
  "build": {
    "appId": "com.conductor.designer",
    "productName": "Conductor Designer",
    "asarUnpack": false,
    "asar": false,
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "index.js",
      "fileStoreServer.js",
      "server-logger.js",
      "resolvers.js",
      "schema.js",
      "electron-main.js",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "forceCodeSigning": false,
      "sign": null,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Conductor Designer"
    },
    "portable": {
      "artifactName": "ConductorDesigner-${version}-portable.${ext}"
    }
  }
}
